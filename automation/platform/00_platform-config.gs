// ============================ 진행바 단계 세트 (상품별) ============================
// 마이페이지 진행바·관리자 목록이 읽는 '현재단계' 라벨 순서. customers-sheet-spec 섹션 02.
var STAGE_FLOW = {
  시그니처: ['신청접수', '상담확정', '상담완료', '계약완료', '입금완료', '제작중', '예식완료', '결과물전달'],
  웨딩스냅: ['신청접수', '촬영확정', '계약완료', '입금완료', '촬영완료', '결과물전달']
};
// 정상 경로를 벗어난 상태(진행바에 위치가 없음 — 별도 표기)
var STAGE_EXCEPTIONS = ['미계약', '취소', '노쇼'];

// 상품타입 → 진행바 단계 배열 (모르는 값이면 시그니처 기본)
function stageFlowFor(product) {
  return STAGE_FLOW[String(product || '').trim()] || STAGE_FLOW['시그니처'];
}

// "지금 할 일" — 현재단계별 다음 행동 한 문장(고객 6원칙: 상태 나열 X, 행동 1개).
// Phase 1에서 실제 도달 단계는 주로 '신청접수'. 이후 단계는 후속 Phase에서 화면이 채워짐.
function nextActionFor(product, stage) {
  var isSnap = String(product || '').trim() === P.PRODUCT_SNAP;
  var MAP = {
    '신청접수': isSnap
      ? '촬영 상담 신청이 접수되었습니다. 디렉터가 일정을 잡아 곧 연락드립니다.'
      : '상담 신청이 접수되었습니다. 디렉터가 일정을 잡아 곧 연락드립니다.',
    '상담확정': '예정된 상담일에 맞춰 준비해 주세요. 변경이 필요하면 카카오톡으로 문의해 주세요.',
    '촬영확정': '예정된 촬영일에 맞춰 준비해 주세요. 변경이 필요하면 카카오톡으로 문의해 주세요.',
    '상담완료': '본 계약서를 준비 중입니다. 준비되면 마이페이지에서 안내드립니다.',
    '계약완료': '계약금 입금을 진행해 주세요. 입금 확인 후 다음 단계가 열립니다.',
    '입금완료': isSnap
      ? '촬영 준비가 진행됩니다. 일정에 맞춰 안내드립니다.'
      : '제작 정보를 입력할 수 있도록 준비 중입니다. 곧 안내드립니다.',
    '제작중': '제작 정보 입력을 이어서 진행해 주세요.',
    '예식완료': '결과물을 준비하고 있습니다. 준비되면 안내드립니다.',
    '촬영완료': '결과물을 준비하고 있습니다. 준비되면 안내드립니다.',
    '결과물전달': '결과물이 준비되었습니다. 마이페이지에서 확인·다운로드해 주세요.',
    '미계약': '아직 계약이 진행되지 않았습니다. 궁금한 점은 카카오톡으로 문의해 주세요.',
    '취소': '신청이 취소되었습니다. 다시 진행을 원하시면 카카오톡으로 문의해 주세요.',
    '노쇼': '예약일에 방문이 확인되지 않았습니다. 카카오톡으로 문의해 주세요.'
  };
  return MAP[String(stage || '').trim()] || '디렉터가 확인 후 다음 단계를 안내드립니다.';
}
